<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ================================================================
             Cron jobs — locked-margin snapshotting
             ================================================================ -->

        <!-- Daily refresh of the running month -->
        <record id="cron_lock_margin_daily" model="ir.cron">
            <field name="name">Flamant KPI: Refresh locked margin (current month)</field>
            <field name="model_id" ref="model_flamant_sales_line"/>
            <field name="state">code</field>
            <field name="code">model._cron_refresh_locked_margin_current_month()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
<field name="nextcall"
                   eval="(DateTime.now().replace(hour=2, minute=0, second=0)
                          + relativedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>

        <!-- Monthly finalization of the previous month -->
        <record id="cron_lock_margin_monthly" model="ir.cron">
            <field name="name">Flamant KPI: Finalize locked margin (previous month)</field>
            <field name="model_id" ref="model_flamant_sales_line"/>
            <field name="state">code</field>
            <field name="code">model._cron_finalize_locked_margin_previous_month()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
<field name="nextcall"
                   eval="((DateTime.now().replace(day=1, hour=3, minute=0, second=0))
                          + relativedelta(months=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>

        <!-- ================================================================
             Saved favorites — two pivot presets
             ================================================================ -->

        <record id="filter_dynamic_margin" model="ir.filters">
            <field name="name">Dynamic Margin</field>
            <field name="model_id">flamant.sales.line</field>
<field name="action_id" ref="action_flamant_sales_line"/>
            <field name="domain">[('basis', '=', 'order_intake')]</field>
            <field name="context">{
                'pivot_measures': ['margin'],
                'pivot_row_groupby': ['orderdate_split:month'],
                'pivot_column_groupby': []
            }</field>
        </record>

        <record id="filter_locked_margin" model="ir.filters">
            <field name="name">Locked Margin</field>
            <field name="model_id">flamant.sales.line</field>
<field name="action_id" ref="action_flamant_sales_line"/>
            <field name="domain">[('basis', '=', 'order_intake'), ('margin_locked', '!=', False)]</field>
            <field name="context">{
                'pivot_measures': ['margin_locked'],
                'pivot_row_groupby': ['orderdate_split:month'],
                'pivot_column_groupby': []
            }</field>
        </record>

        <record id="filter_invoiced_dynamic_margin" model="ir.filters">
            <field name="name">Dynamic Margin</field>
            <field name="model_id">flamant.sales.line</field>
            <field name="action_id" ref="action_flamant_invoiced_sales_line"/>
            <field name="domain">[('basis', '=', 'invoiced')]</field>
            <field name="context">{
                'pivot_measures': ['margin'],
                'pivot_row_groupby': ['date:month'],
                'pivot_column_groupby': []
            }</field>
        </record>

        <record id="filter_invoiced_locked_margin" model="ir.filters">
            <field name="name">Locked Margin</field>
            <field name="model_id">flamant.sales.line</field>
            <field name="action_id" ref="action_flamant_invoiced_sales_line"/>
            <field name="domain">[('basis', '=', 'invoiced'), ('margin_locked', '!=', False)]</field>
            <field name="context">{
                'pivot_measures': ['margin_locked'],
                'pivot_row_groupby': ['date:month'],
                'pivot_column_groupby': []
            }</field>
        </record>

    </data>
</odoo>
