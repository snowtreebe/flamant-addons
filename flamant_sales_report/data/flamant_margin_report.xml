        <field name="code">FLM_PCT_OTHER</field>
        <field name="sequence">4</field>
    </record>
    <record id="flamant_margin_expr_other_pct" model="account.report.expression">
        <field name="report_line_id" ref="flamant_margin_line_other_pct"/>
        <field name="label">balance</field>
        <field name="engine">aggregation</field>
        <field name="formula">FLM_MARGE_OTHER.balance / FLM_REV_OTHER.balance</field>
        <field name="subformula">ignore_zero_division</field>
        <field name="figure_type">percentage</field>
    </record>

