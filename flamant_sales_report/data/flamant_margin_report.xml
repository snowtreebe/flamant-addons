        <field name="sequence">13</field>
    </record>
    <record id="flamant_margin_detail_expr_shops_marge" model="account.report.expression">
        <field name="report_line_id" ref="flamant_margin_detail_line_shops_marge"/>
        <field name="label">balance</field>
        <field name="engine">aggregation</field>
        <field name="formula">FLM_D_REV_SHOPS.balance - FLM_D_COGS_SHOPS.balance</field>
    </record>
    <record id="flamant_margin_detail_line_shops_pct" model="account.report.line">
        <field name="report_id" ref="flamant_margin_report_detail"/>
        <field name="parent_id" ref="flamant_margin_detail_line_shops"/>
        <field name="name">% Marge</field>
        <field name="code">FLM_D_PCT_SHOPS</field>
        <field name="sequence">14</field>
    </record>
    <record id="flamant_margin_detail_expr_shops_pct" model="account.report.expression">
        <field name="report_line_id" ref="flamant_margin_detail_line_shops_pct"/>
        <field name="label">balance</field>
        <field name="engine">aggregation</field>
        <field name="formula">100 * FLM_D_MARGE_SHOPS.balance / FLM_D_REV_SHOPS.balance</field>
        <field name="subformula">ignore_zero_division</field>
        <field name="figure_type">percentage</field>
    </record>

