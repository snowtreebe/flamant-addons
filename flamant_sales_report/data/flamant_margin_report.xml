        <field name="formula">FLM_D_REV_TOTAL.balance - FLM_D_COGS_TOTAL.balance</field>
    </record>
    <record id="flamant_margin_detail_line_total_pct" model="account.report.line">
        <field name="report_id" ref="flamant_margin_report_detail"/>
        <field name="parent_id" ref="flamant_margin_detail_line_total"/>
        <field name="name">% Marge</field>
        <field name="code">FLM_D_PCT_TOTAL</field>
        <field name="sequence">104</field>
    </record>
    <record id="flamant_margin_detail_expr_total_pct" model="account.report.expression">
        <field name="report_line_id" ref="flamant_margin_detail_line_total_pct"/>
        <field name="label">balance</field>
        <field name="engine">aggregation</field>
        <field name="formula">100 * FLM_D_MARGE_TOTAL.balance / FLM_D_REV_TOTAL.balance</field>
        <field name="subformula">ignore_zero_division</field>
        <field name="figure_type">percentage</field>
    </record>

    <!-- Menu items -->
    <record id="flamant_margin_report_action" model="ir.actions.client">
        <field name="name">Marge-rapport</field>
        <field name="tag">account_report</field>
        <field name="context" eval="{'report_id': ref('flamant_margin_report')}"/>
    </record>
    <record id="flamant_margin_report_detail_action" model="ir.actions.client">
        <field name="name">Marge-rapport (detail)</field>
        <field name="tag">account_report</field>
        <field name="context" eval="{'report_id': ref('flamant_margin_report_detail')}"/>
    </record>


</odoo>
