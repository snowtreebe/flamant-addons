        <field name="formula">[('account_id.code', '=like', '70%'), ('move_id.team_id.x_channel', '=', 'other')]</field>
        <field name="subformula">-sum</field>
    </record>
    <record id="flamant_margin_line_other_cogs" model="account.report.line">
        <field name="report_id" ref="flamant_margin_report"/>
        <field name="parent_id" ref="flamant_margin_line_other"/>
        <field name="name">COGS</field>
        <field name="code">FLM_COGS_OTHER</field>
        <field name="sequence">2</field>
    </record>
    <record id="flamant_margin_expr_other_cogs" model="account.report.expression">
        <field name="report_line_id" ref="flamant_margin_line_other_cogs"/>
        <field name="label">balance</field>
        <field name="engine">domain</field>
        <field name="formula">[('account_id.code', '=like', '604%'), ('move_id.team_id.x_channel', '=', 'other')]</field>
        <field name="subformula">sum</field>
    </record>
    <record id="flamant_margin_line_other_marge" model="account.report.line">
        <field name="report_id" ref="flamant_margin_report"/>
        <field name="parent_id" ref="flamant_margin_line_other"/>
        <field name="name">Marge</field>
        <field name="code">FLM_MARGE_OTHER</field>
        <field name="sequence">3</field>
    </record>
    <record id="flamant_margin_expr_other_marge" model="account.report.expression">
        <field name="report_line_id" ref="flamant_margin_line_other_marge"/>
        <field name="label">balance</field>
        <field name="engine">aggregation</field>
        <field name="formula">FLM_REV_OTHER.balance - FLM_COGS_OTHER.balance</field>
    </record>
    <record id="flamant_margin_line_other_pct" model="account.report.line">
        <field name="report_id" ref="flamant_margin_report"/>
        <field name="parent_id" ref="flamant_margin_line_other"/>
