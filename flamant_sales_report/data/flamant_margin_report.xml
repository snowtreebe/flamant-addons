    <record id="flamant_margin_expr_total_marge" model="account.report.expression">
        <field name="report_line_id" ref="flamant_margin_line_total_marge"/>
        <field name="label">balance</field>
        <field name="engine">aggregation</field>
        <field name="formula">FLM_REV_TOTAL.balance - FLM_COGS_TOTAL.balance</field>
    </record>
    <record id="flamant_margin_line_total_pct" model="account.report.line">
        <field name="report_id" ref="flamant_margin_report"/>
        <field name="parent_id" ref="flamant_margin_line_total"/>
        <field name="name">% Marge</field>
        <field name="code">FLM_PCT_TOTAL</field>
        <field name="sequence">4</field>
    </record>
    <record id="flamant_margin_expr_total_pct" model="account.report.expression">
