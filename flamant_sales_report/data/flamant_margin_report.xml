    <record id="flamant_margin_expr_total_omzet" model="account.report.expression">
        <field name="report_line_id" ref="flamant_margin_line_total"/>
        <field name="label">omzet</field>
        <field name="engine">aggregation</field>
        <field name="formula">FLM_SHOPS.omzet + FLM_ECOM.omzet + FLM_WHS.omzet + FLM_FRAN.omzet + FLM_OUT.omzet + FLM_HOME.omzet + FLM_OTHER.omzet</field>
