<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Marge-rapport per kanaal
        ========================
        Native account.report (Enterprise) that breaks revenue + COGS down by
        Flamant sales channel (Shops / Ecommerce / Wholesale / Franchise /
        Outlet / Flamant@Home / Other) and computes Marge and %Marge per
        channel plus a grand total.

        Revenue is detected on accounts matching 70%, COGS on 604%, both
        filtered by the move's sales team channel (crm.team.x_channel).

        The standard account.report filters (date range, period comparison,
        growth comparison, budgets) are enabled — users pick comparison
        columns from the UI.
    -->

    <record id="flamant_margin_report" model="account.report">
        <field name="name">Marge-rapport per kanaal</field>
        <field name="filter_date_range">True</field>
        <field name="filter_period_comparison">True</field>
        <field name="filter_growth_comparison">True</field>
        <field name="filter_budgets">True</field>
        <field name="filter_show_draft">True</field>
        <field name="filter_unfold_all">True</field>
        <field name="default_opening_date_filter">this_month</field>
        <field name="column_ids">
            <record id="flamant_margin_col_balance" model="account.report.column">
                <field name="name">Bedrag</field>
                <field name="expression_label">balance</field>
                <field name="figure_type">monetary</field>
            </record>
        </field>
    </record>

    <!--
        ============================================================
        Reusable line template
        ============================================================
        Per channel we emit four lines:
          - REV_<channel>      : revenue (account 70%, channel filter), -sum
          - COGS_<channel>     : cost of goods (account 604%, channel filter), sum
          - MARGE_<channel>    : aggregation = REV - COGS
          - PCT_<channel>      : aggregation = MARGE / REV * 100
        The channel header line has children unfolded by default.
    -->

    <!-- ============ SHOPS ============ -->
    <record id="flamant_margin_line_shops" model="account.report.line">
        <field name="report_id" ref="flamant_margin_report"/>
        <field name="name">Shops</field>
        <field name="code">FLM_SHOPS</field>
        <field name="sequence">10</field>
        <field name="hierarchy_level">0</field>
    </record>
    <record id="flamant_margin_line_shops_rev" model="account.report.line">
        <field name="report_id" ref="flamant_margin_report"/>
        <field name="parent_id" ref="flamant_margin_line_shops"/>
        <field name="name">Omzet</field>
        <field name="code">FLM_REV_SHOPS</field>
        <field name="sequence">1</field>
    </record>
    <record id="flamant_margin_expr_shops_rev" model="account.report.expression">
        <field name="report_line_id" ref="flamant_margin_line_shops_rev"/>
        <field name="label">balance</field>
        <field name="engine">domain</field>
        <field name="formula">[('account_id.code', '=like', '70%'), ('move_id.team_id.x_channel', '=', 'shops')]</field>
        <field name="subformula">-sum</field>
    </record>
    <record id="flamant_margin_line_shops_cogs" model="account.report.line">
        <field name="report_id" ref="flamant_margin_report"/>
        <field name="parent_id" ref="flamant_margin_line_shops"/>
        <field name="name">COGS</field>
        <field name="code">FLM_COGS_SHOPS</field>
        <field name="sequence">2</field>
    </record>
    <record id="flamant_margin_expr_shops_cogs" model="account.report.expression">
        <field name="report_line_id" ref="flamant_margin_line_shops_cogs"/>
        <field name="label">balance</field>
        <field name="engine">domain</field>
        <field name="formula">[('account_id.code', '=like', '604%'), ('move_id.team_id.x_channel', '=', 'shops')]</field>
        <field name="subformula">sum</field>
    </record>
    <record id="flamant_margin_line_shops_marge" model="account.report.line">
        <field name="report_id" ref="flamant_margin_report"/>
        <field name="parent_id" ref="flamant_margin_line_shops"/>
        <field name="name">Marge</field>
        <field name="code">FLM_MARGE_SHOPS</field>
        <field name="sequence">3</field>
    </record>
    <record id="flamant_margin_expr_shops_marge" model="account.report.expression">
        <field name="report_line_id" ref="flamant_margin_line_shops_marge"/>
        <field name="label">balance</field>
        <field name="engine">aggregation</field>
        <field name="formula">FLM_REV_SHOPS.balance - FLM_COGS_SHOPS.balance</field>
    </record>
    <record id="flamant_margin_line_shops_pct" model="account.report.line">
        <field name="report_id" ref="flamant_margin_report"/>
        <field name="parent_id" ref="flamant_margin_line_shops"/>
        <field name="name">% Marge</field>
        <field name="code">FLM_PCT_SHOPS</field>
        <field name="sequence">4</field>
    </record>
    <record id="flamant_margin_expr_shops_pct" model="account.report.expression">
        <field name="report_line_id" ref="flamant_margin_line_shops_pct"/>
        <field name="label">balance</field>
        <field name="engine">aggregation</field>
        <field name="formula">FLM_MARGE_SHOPS.balance / FLM_REV_SHOPS.balance</field>
        <field name="subformula">ignore_zero_division</field>
        <field name="figure_type">percentage</field>
    </record>

