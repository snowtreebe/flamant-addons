        <field name="report_line_id" ref="flamant_margin_line_total_cogs"/>
        <field name="label">balance</field>
        <field name="engine">aggregation</field>
        <field name="formula">FLM_COGS_SHOPS.balance + FLM_COGS_ECOM.balance + FLM_COGS_WHS.balance + FLM_COGS_FRAN.balance + FLM_COGS_OUT.balance + FLM_COGS_HOME.balance + FLM_COGS_OTHER.balance</field>
    </record>
    <record id="flamant_margin_line_total_marge" model="account.report.line">
        <field name="report_id" ref="flamant_margin_report"/>
        <field name="parent_id" ref="flamant_margin_line_total"/>
        <field name="name">Marge</field>
        <field name="code">FLM_MARGE_TOTAL</field>
        <field name="sequence">3</field>
