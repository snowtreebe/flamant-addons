<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        ================================================================
        Marge-rapport per business unit
        ================================================================
        Native Odoo Enterprise account.report. Layout:
          - 4 columns: Omzet · COGS · Bruto Marge · % Marge
          - Rows grouped per business unit (BU):
              · Retail      (shops channel; split per country: BE / FR)
              · Ecommerce   (split per partner country: BE / FR / INT)
              · Wholesale   (single row)
              · Other       (= Outlet channel, single row)
              · TOTAAL
          - Default opening date: this_month (toggle in UI)
          - Budget overlay enabled (filter_budgets=True)

        Country logic differs by BU:
          - Retail country = team.x_country_code (shop's physical country)
          - Ecommerce country = partner_shipping_id.country_id.code
            (BE / FR explicitly; everything else lumped as INT)
    -->

    <record id="flamant_bu_report" model="account.report">
        <field name="name">Marge-rapport per business unit</field>
        <field name="filter_date_range">True</field>
        <field name="filter_period_comparison">True</field>
        <field name="filter_growth_comparison">True</field>
        <field name="filter_budgets">True</field>
        <field name="filter_show_draft">True</field>
        <field name="filter_unfold_all">True</field>
        <field name="default_opening_date_filter">this_month</field>
        <field name="column_ids">
            <record id="flamant_bu_col_omzet" model="account.report.column">
                <field name="name">Omzet</field>
                <field name="expression_label">omzet</field>
                <field name="figure_type">monetary</field>
                <field name="sequence">1</field>
            </record>
            <record id="flamant_bu_col_cogs" model="account.report.column">
                <field name="name">COGS</field>
                <field name="expression_label">cogs</field>
                <field name="figure_type">monetary</field>
                <field name="sequence">2</field>
            </record>
            <record id="flamant_bu_col_marge" model="account.report.column">
                <field name="name">Bruto Marge</field>
                <field name="expression_label">marge</field>
                <field name="figure_type">monetary</field>
                <field name="sequence">3</field>
            </record>
            <record id="flamant_bu_col_pct" model="account.report.column">
                <field name="name">% Bruto Marge</field>
                <field name="expression_label">pct</field>
                <field name="figure_type">percentage</field>
                <field name="sequence">4</field>
            </record>
        </field>
    </record>

    <!-- ============ RETAIL (Shops) ============ -->
    <record id="flamant_bu_line_retail" model="account.report.line">
        <field name="report_id" ref="flamant_bu_report"/>
        <field name="name">Retail</field>
        <field name="code">FLM_BU_RETAIL</field>
        <field name="sequence">10</field>
    </record>
    <record id="flamant_bu_expr_retail_omzet" model="account.report.expression">
        <field name="report_line_id" ref="flamant_bu_line_retail"/>
        <field name="label">omzet</field>
        <field name="engine">domain</field>
        <field name="formula">[('account_id.code', '=like', '70%'), ('move_id.team_id.x_channel', '=', 'shops')]</field>
        <field name="subformula">-sum</field>
    </record>
    <record id="flamant_bu_expr_retail_cogs" model="account.report.expression">
        <field name="report_line_id" ref="flamant_bu_line_retail"/>
        <field name="label">cogs</field>
        <field name="engine">domain</field>
        <field name="formula">[('account_id.code', '=like', '604%'), ('move_id.team_id.x_channel', '=', 'shops')]</field>
        <field name="subformula">sum</field>
    </record>
    <record id="flamant_bu_expr_retail_marge" model="account.report.expression">
        <field name="report_line_id" ref="flamant_bu_line_retail"/>
        <field name="label">marge</field>
        <field name="engine">aggregation</field>
        <field name="formula">FLM_BU_RETAIL.omzet - FLM_BU_RETAIL.cogs</field>
    </record>
    <record id="flamant_bu_expr_retail_pct" model="account.report.expression">
        <field name="report_line_id" ref="flamant_bu_line_retail"/>
        <field name="label">pct</field>
        <field name="engine">aggregation</field>
        <field name="formula">100 * FLM_BU_RETAIL.marge / FLM_BU_RETAIL.omzet</field>
        <field name="subformula">ignore_zero_division</field>
    </record>

